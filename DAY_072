#include <stdio.h>
#include <string.h>

int main() {
    char s[1000];
    scanf("%s", s);

    int seen[26] = {0};

    for (int i = 0; s[i] != '\0'; i++) {
        int index = s[i] - 'a';

        if (seen[index] == 1) {
            printf("%c", s[i]);
            return 0;
        }

        seen[index] = 1;
    }

    printf("-1");
    return 0;
}
