#include <stdio.h>
#include <stdlib.h>

// Merge function that counts inversions
int merge(int arr[], int temp[], int left, int mid, int right) {
    int i = left;      // left subarray
    int j = mid;       // right subarray
    int k = left;      // temp array index
    int inv_count = 0;

    while (i <= mid - 1 && j <= right) {
        if (arr[i] <= arr[j]) {
            temp[k++] = arr[i++];
        } else {
            temp[k++] = arr[j++];
            inv_count += (mid - i); // Count inversions
        }
    }

    // Copy remaining elements
    while (i <= mid - 1)
        temp[k++] = arr[i++];

    while (j <= right)
        temp[k++] = arr[j++];

    // Copy back to original array
    for (i = left; i <= right; i++)
        arr[i] = temp[i];

    return inv_count;
}

// Merge sort function
int mergeSort(int arr[], int temp[], int left, int right) {
    int mid, inv_count = 0;

    if (right > left) {
        mid = (left + right) / 2;

        inv_count += mergeSort(arr, temp, left, mid);
        inv_count += mergeSort(arr, temp, mid + 1, right);

        inv_count += merge(arr, temp, left, mid + 1, right);
    }

    return inv_count;
}

// Wrapper function
int countInversions(int arr[], int n) {
    int *temp = (int *)malloc(n * sizeof(int));
    int result = mergeSort(arr, temp, 0, n - 1);
    free(temp);
    return result;
}

// Print array
void printArray(int arr[], int n) {
    for (int i = 0; i < n; i++)
        printf("%d ", arr[i]);
    printf("\n");
}

int main() {
    int arr[] = {2, 4, 1, 3, 5};
    int n = sizeof(arr) / sizeof(arr[0]);

    int inv = countInversions(arr, n);

    printf("Number of inversions: %d\n", inv);
    printf("Sorted array: ");
    printArray(arr, n);

    return 0;
}
