#include <stdio.h>

int main()
{
    int n, m;
    int i, j;
    int u, v;

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    printf("Enter number of edges: ");
    scanf("%d", &m);

    int adj[n][n];

    // Initialize matrix with 0
    for (i = 0; i < n; i++)
    {
        for (j = 0; j < n; j++)
        {
            adj[i][j] = 0;
        }
    }

    printf("Enter the edges (u v):\n");

    for (i = 0; i < m; i++)
    {
        scanf("%d %d", &u, &v);

        adj[u][v] = 1;     // Directed edge

        adj[v][u] = 1;     // Remove this line if graph is directed
    }

    printf("\nAdjacency Matrix:\n");

    for (i = 0; i < n; i++)
    {
        for (j = 0; j < n; j++)
        {
            printf("%d ", adj[i][j]);
        }
        printf("\n");
    }

    return 0;
}
